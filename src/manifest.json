{
  "manifest_version": 3,
  "name": "Legado Source Generator",
  "version": "0.1.0",
  "description": "Generate Legado book source rules from web pages",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "sidePanel"
  ],
  "action": {
    "default_title": "Legado Source Generator"
  },
  "side_panel": {
    "default_path": "popup/index.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["lib/selector-generator.js", "content/picker.js"],
      "css": ["content/picker.css"]
    }
  ]
}